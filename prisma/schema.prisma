generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FIELD_FORCE
  SUPERVISOR
}

enum ScheduleDay {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

enum WeekParity {
  ODD
  EVEN
}

enum TaskStatus {
  PENDING
  CHECKED_IN
  COMPLETED
  MISSED
}

model User {
  id                String        @id @default(cuid())
  name              String
  email             String        @unique
  passwordHash      String
  role              UserRole
  phone             String?
  territory         String?
  territoryGroup    String?
  lastKnownLat      Float?
  lastKnownLon      Float?
  lastKnownAccuracy Float?
  lastPingAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  assignedOutlets   Outlet[]      @relation("FieldForceOutlets")
  supervisedOutlets Outlet[]      @relation("SupervisorOutlets")
  outletAssignments Assignment[]
  tasks             Task[]
  locationPings     LocationPing[]
  dutySessions      DutySession[]

  @@index([role])
}

model Outlet {
  id              String       @id @default(cuid())
  storeCode       String       @unique
  name            String
  address         String
  subdistrict     String?
  regency         String?
  latitude        Float
  longitude       Float
  district        String?
  territory       String?
  territoryGroup  String?
  oddScheduleDay  ScheduleDay?
  evenScheduleDay ScheduleDay?
  supervisorId    String?
  fieldForceId    String?
  supervisorPhone String?
  typeOutlet      String?
  visualPposm     String?
  brand           String?
  size            String?
  sunscreenCount  Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  supervisor      User?        @relation("SupervisorOutlets", fields: [supervisorId], references: [id], onDelete: SetNull)
  fieldForce      User?        @relation("FieldForceOutlets", fields: [fieldForceId], references: [id], onDelete: SetNull)
  assignments     Assignment[]
  tasks           Task[]

  @@index([fieldForceId])
  @@index([supervisorId])
  @@index([territory])
}

model Assignment {
  id        String   @id @default(cuid())
  userId    String
  outletId  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlet    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([userId, outletId])
  @@index([userId, active])
  @@index([outletId, active])
}

model Task {
  id                    String       @id @default(cuid())
  outletId              String
  userId                String
  scheduledDate         DateTime     @db.Date
  weekParity            WeekParity
  scheduleDay           ScheduleDay
  status                TaskStatus   @default(PENDING)
  checkInAt             DateTime?
  checkInLat            Float?
  checkInLon            Float?
  checkInDistanceMeters Float?
  checkOutAt            DateTime?
  checkOutLat           Float?
  checkOutLon           Float?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  outlet                Outlet       @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([outletId, userId, scheduledDate])
  @@index([userId, scheduledDate])
  @@index([scheduledDate, status])
}

model DutySession {
  id          String         @id @default(cuid())
  userId      String
  startedAt   DateTime       @default(now())
  endedAt     DateTime?
  startedLat  Float?
  startedLon  Float?
  endedLat    Float?
  endedLon    Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationPings LocationPing[]

  @@index([userId, endedAt])
}

model LocationPing {
  id            String       @id @default(cuid())
  userId        String
  dutySessionId String?
  latitude      Float
  longitude     Float
  accuracy      Float?
  speed         Float?
  pingedAt      DateTime     @default(now())
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dutySession   DutySession? @relation(fields: [dutySessionId], references: [id], onDelete: SetNull)

  @@index([userId, pingedAt])
  @@index([pingedAt])
}
